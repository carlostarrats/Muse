    },
    "Looks for images in this folder that have no tags and generates tags for them in the background. Images that already have tags are left alone. Only automatic tags are created — tags you added by hand aren't restored.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recherche dans ce dossier les images sans étiquette et génère leurs étiquettes en arrière-plan. Les images déjà étiquetées ne sont pas modifiées. Seules des étiquettes automatiques sont créées — les étiquettes que vous avez ajoutées à la main ne sont pas restaurées."
          }
        }
      }
    },
    "Manage iCloud Shares…": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérer les partages iCloud…"
          }
        }
      }
