    },
    "The collection is removed. Your images stay on disk.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La collection est supprimée. Vos images restent sur le disque."
          }
        }
      }
    },
    "The folder was renamed, but updating its tags failed.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le dossier a été renommé, mais la mise à jour de ses étiquettes a échoué."
          }
        }
      }
    },
    "The quick brown fox jumps over the lazy dog.": {
      "localizations": {
