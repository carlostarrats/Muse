      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À propos de Muse"
          }
        }
      }
    },
    "About Muse — how indexing, analysis, collections, and tags work": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À propos de Muse — fonctionnement de l'indexation, de l'analyse, des collections et des étiquettes"
