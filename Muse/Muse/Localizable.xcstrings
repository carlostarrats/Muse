          }
        }
      }
    },
    "Find Duplicates in Folder": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rechercher les doublons dans le dossier"
          }
        }
      }
    },
    "Find Duplicates in the File menu surfaces copies — byte-for-byte identical files, visually similar images, and matching filenames — so you can review and clear them out to the Trash.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rechercher les doublons, dans le menu Fichier, fait remonter les copies — fichiers identiques octet par octet, images visuellement similaires et noms de fichiers correspondants — afin que vous puissiez les examiner et les envoyer dans la corbeille."
          }
        }
      }
    },
