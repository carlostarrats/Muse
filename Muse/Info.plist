<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sparkle self-update (direct-distribution build). The feed is the
	     signed appcast published on GitHub Releases; every download is
	     verified against SUPublicEDKey. SUEnableAutomaticChecks = true so
	     Sparkle checks quietly in the background (no first-run consent prompt,
	     no UI unless an update is actually available) — only ever an update
	     check, never any data collection. -->
	<key>SUFeedURL</key>
	<string>https://github.com/carlostarrats/Muse/releases/latest/download/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>QZNDbCzR71yEGGdAzXVbSS5qcOQxhi86Q6aNd+Av9+I=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<!-- Required for a SANDBOXED app to install updates: routes the install
	     through Sparkle's InstallerLauncher XPC service (paired with the
	     mach-lookup entitlements). Without it the installer can't launch. -->
	<key>SUEnableInstallerLauncherService</key>
	<true/>
	<!-- Google OAuth native redirect (reverse-client-id custom scheme). The
	     actual scheme string is filled when the owner sets DriveConfig.clientID
	     (com.googleusercontent.apps.<reverse-client-id>) — see
	     web/share/README.md. Used by ASWebAuthenticationSession to receive the
	     authorization code. No secret involved (PKCE public client). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.tarrats.Muse.googleoauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.572618611419-tpnrrjdskcfknc1157em3bamudbu9pt7</string>
			</array>
		</dict>
	</array>
	<key>NSUbiquitousContainers</key>
	<dict>
		<key>iCloud.com.tarrats.Muse</key>
		<dict>
			<key>NSUbiquitousContainerIsDocumentScopePublic</key>
			<true/>
			<key>NSUbiquitousContainerName</key>
			<string>Muse</string>
			<key>NSUbiquitousContainerSupportedFolderLevels</key>
			<string>Any</string>
		</dict>
	</dict>
</dict>
</plist>
